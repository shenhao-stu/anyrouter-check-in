{
  "manifest_version": 3,
  "name": "AnyRouter Cookie Updater",
  "version": "1.4.1",
  "version_name": "1.4.1-fengling.1",
  "description": "自动提取 AnyRouter 等平台的 session cookie，推送到 GitHub Actions Environment Secrets",
  "permissions": [
    "cookies",
    "tabs",
    "scripting",
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://*/*",
    "https://api.github.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
